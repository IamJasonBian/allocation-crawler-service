# Copy to terraform.tfvars and fill in values
# Sensitive values can also be set via TF_VAR_* environment variables

service_name = "accra"
repo_url     = "https://github.com/IamJasonBian/allocation-crawler-service"
branch       = "main"
plan         = "starter"
region       = "oregon"

# Redis (e.g. from Redis Cloud, Upstash, or Render Redis)
redis_host     = ""
redis_port     = 6379
redis_password = ""

# Auth
jwt_secret          = ""  # openssl rand -hex 32
google_client_id    = ""
google_client_secret = ""
require_auth        = false

# Integrations
slack_webhook_url = ""

# Storage
enable_disk  = false
disk_size_gb = 1
